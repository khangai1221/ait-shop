# ── Postgres ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (Transaction pooler)
DATABASE_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Public anon key (safe to expose to the browser — RLS is the real guard)
# Supabase → Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=

# ── Clerk ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that are treated as admins even
# before their DB row has is_admin = true.
ADMIN_EMAILS=

# ── Anthropic (required for PDF + image import) ───────────────────────────────
# Used for PDF product import (reads the full catalog via Claude) and
# JPG/PNG Vision extraction. Without this key PDF import falls back to
# basic text extraction which may not work for complex PDFs.
ANTHROPIC_API_KEY=
